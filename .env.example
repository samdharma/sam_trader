# SAM Trader V3 — Environment variables template
# Copy to .env and fill in real values. NEVER commit .env.

# Trader identity
TRADER_ID=sam_trader

# Trading environment: paper | live
SAM_ENV=paper

# ---- IB Gateway ----
IB_ENABLED=true
IB_GATEWAY_HOST=sam-ib-gateway
IB_GATEWAY_PORT=4004
IB_GATEWAY_CLIENT_ID=11
IB_ACCOUNT_ID=
IB_SYMBOLS=TSLA.NASDAQ,AAPL.NASDAQ,NVDA.NASDAQ
IB_TRADING_MODE=paper  # Consumed by the IB Gateway Docker container (docker-compose.yml), not by sam-trader Python code
IB_READ_ONLY_API=false
IB_MARKET_DATA_TYPE=REALTIME
TWS_USERID=
TWS_PASSWORD=

# IB Gateway VNC (GUI access for 2FA)
IB_VNC_PORT=5900
VNC_SERVER_PASSWORD=sam123

# IB Gateway 2FA / session recovery (gnzsnz/ib-gateway image)
EXISTING_SESSION_DETECTED_ACTION=primary
TWOFA_TIMEOUT_ACTION=restart
TWOFA_EXIT_INTERVAL=180
RELOGIN_AFTER_TWOFA_TIMEOUT=yes

# Entrypoint control
WAIT_FOR_IB_GATEWAY=1
WAIT_FOR_FUTU_OPEND=1
WAIT_TIMEOUT=60

# ==========================================================================
# Futu OpenD (FUTUBULL broker)
# ==========================================================================
#
# Two types of account IDs exist in the Futu system — know the difference:
#
#   LOGIN ACCOUNT (FUTU_ACCOUNT_ID)
#     Your master Futubull login. Used by the sam-futu-opend container to
#     authenticate with Futu servers.  This is NOT a trading account.
#     Typically a long integer like 281756477933385889.
#
#   PAPER TRADING ACCOUNT (FUTU_PAPER_ACCOUNT_ID)
#     A sub-account returned by get_acc_list().  This IS a trading account.
#     Typically a shorter integer like 19064358.  Auto-discovered at startup
#     by matching sim_acc_type from market_config.yaml.
#     Set FUTU_PAPER_ACCOUNT_ID ONLY if auto-discovery fails.
#
# See: docs/reference/ACCOUNT_DISCOVERY.md
#      docs/user/FUTU_FIRST_LOGIN.md

# Enable Futu broker integration
FUTU_ENABLED=false

# OpenD container hostname / address
FUTU_OPEND_HOST=sam-futu-opend

# OpenD API port (Protobuf protocol)
FUTU_OPEND_PORT=11111

# OpenD telnet admin port
FUTU_OPEND_TELNET_PORT=22222

# OpenD bind address inside container. MUST be 0.0.0.0 for Docker networking.
# Do NOT set to 127.0.0.1 — other containers (sam-trader) cannot reach it.
FUTU_OPEND_IP=0.0.0.0

# OpenD UI language: en | zh_CN | zh_HK
FUTU_OPEND_LANG=en

# MUST match futu-api SDK version in pyproject.toml / docker/requirements.txt
FUTU_OPEND_VER=10.6.6608

# Trading environment: SIMULATE (paper) | REAL (live)
# This controls BOTH the trd_env on API calls AND the account discovery
# strategy (auto-discovery vs direct FUTU_ACCOUNT_ID lookup).
FUTU_TRD_ENV=SIMULATE

# Legacy market selector. Deprecated — prefer MARKET=US|HK instead.
# Only used as fallback when MARKET is not set.
FUTU_TRD_MARKET=US

# ── Account credentials ──────────────────────────────────────────────────

# REQUIRED. Your Futubull master login account ID.
# Used by sam-futu-opend container to authenticate with Futu servers.
# This is NOT a trading account — see FUTU_PAPER_ACCOUNT_ID below.
FUTU_ACCOUNT_ID=

# REQUIRED. MD5 hash of your Futubull login password (32-char hex, lowercase).
# Generate: echo -n 'your_password' | md5sum
FUTU_ACCOUNT_PWD_MD5=

# OPTIONAL. Explicit paper trading account override.
# Set this ONLY when auto-discovery cannot find the correct paper account.
#   When to set:
#     - Auto-discovery logs "FUTU ACCOUNT DISCOVERY FAILED"
#     - Your sim_acc_type doesn't match market_config.yaml expectations
#     - You want to pin a specific paper sub-account
#   How to find the value:
#     Run get_acc_list() via Futu OpenD and look for SIMULATE accounts
#     matching your configured market and sim_acc_type.
#   Format: raw integer, e.g. 19064358 (NOT "FUTU-19064358")
FUTU_PAPER_ACCOUNT_ID=

# OPTIONAL. Trade password for the Futu account (if set in Futubull).
# Rarely needed for paper trading.
FUTU_TRADE_PASSWORD=

# OPTIONAL. RSA private key PEM for cross-network encryption.
# Auto-generated if docker/futu-opend/futu.pem exists.
FUTU_RSA_PRIVATE_KEY=

# REQUIRED for REAL mode. MD5 hash of the trade unlock password.
# Not needed for SIMULATE (paper) trading.
FUTU_UNLOCK_PWD_MD5=

# Interval (seconds) for keep-alive query_subscription() calls.
# Prevents OpenD RemoteClose idle timeout. 0 = disabled.
# Default 1800 (30 minutes) is safe for all markets.
FUTU_KEEP_ALIVE_INTERVAL_SECS=1800

# Default order time-in-force: DAY | GTC | IOC
# Overrides per-market default_time_in_force from market_config.yaml.
# Individual strategies can override via bundles.yaml time_in_force field.
# DAY is the recommended default — Futu paper trading rejects GTC orders.
# DEFAULT_TIME_IN_FORCE=DAY

# ---- Redis (Nautilus cache state persistence) ----
REDIS_HOST=sam-redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- PostgreSQL ----
POSTGRES_HOST=sam-postgres
POSTGRES_PORT=5432
POSTGRES_DB=sam_trader
POSTGRES_USER=sam
POSTGRES_PASSWORD=sam_secret

# ---- State persistence (requires Redis) ----
STATE_SAVE_ENABLED=true
STATE_LOAD_ENABLED=true
# Timeout (seconds) for the graceful restart state-save handshake
STATE_SAVE_HANDSHAKE_TIMEOUT=30

# ---- Actors ----
ACTOR_BAR_RESUB_ENABLED=true
ACTOR_JOURNAL_ENABLED=true
ACTOR_HEALTH_ENABLED=true
ACTOR_REJECTION_MONITOR_ENABLED=true
ACTOR_REALIZED_PNL_ENABLED=true
ACTOR_POSITION_SNAPSHOT_ENABLED=true

# ---- Risk Engine (Nautilus LiveRiskEngine — pre-trade filter) ----
# Max orders per time window (format: "count/interval", e.g. "100/00:00:01")
RISK_MAX_ORDER_SUBMIT_RATE=100/00:00:01
RISK_MAX_ORDER_MODIFY_RATE=100/00:00:01
# Per-instrument notional caps (JSON dict of InstrumentId → cap, e.g. {"AAPL.NASDAQ": 100000})
RISK_MAX_NOTIONAL_PER_ORDER=
# Emergency bypass: set to 1 to skip ALL pre-trade risk checks
RISK_BYPASS=0

# ---- Backup ----
BACKUP_HOST_DIR=~/Documents/ai_agent_docs/backup-sam_trader_v3
BACKUP_RETENTION_DAYS=30

# ---- Logging ----
LOG_LEVEL=INFO

# ==========================================================================
# Market Selector — drives all per-market configuration
# ==========================================================================
#
# REQUIRED for multi-market operations.  Sets the active market at startup.
# Valid values: US | HK
#
# This single variable controls:
#   - Which market_config.yaml entry is loaded
#   - Futu trade context market (trd_market)
#   - Futu paper account discovery filter (sim_acc_type)
#   - IBKR enable/disable (ib_enabled)
#   - Order routing venues (routing_venues)
#   - Session timezone and trading hours
#   - Pre-market pipeline schedule
#   - SOD readiness check and EOD report times
#   - All actor timezone-aware scheduling
#
# When changing markets, restart sam-trader (via orchestrator or manually):
#   docker compose restart sam-trader
#
# If empty, the system falls back to individual env vars (FUTU_TRD_MARKET,
# IB_ENABLED, HEALTH_MONITOR_MARKET, BAR_RESUB_MARKET) — but this legacy
# path is deprecated and will be removed.
MARKET=US

LOG_RETENTION_DAYS=30
LOG_MAX_SIZE_MB=100

# ---- Deployment window (HH:MM-HH:MM format, HKT) ----
DEPLOY_WINDOW=05:00-08:00

# ---- Pre-market pipeline schedule (HH:MM format, market-local time) ----
# The pipeline derives its schedule from market_config.yaml.  This env var
# is optional and overrides the default only when set.
#   US: premarket_pipeline_time = 08:30 ET  (≈ 20:30 HKT summer / 21:30 HKT winter)
#   HK: premarket_pipeline_time = 07:30 HKT
PIPELINE_SCHEDULE=08:00

# ---- Market Calendar (holidays + early closes) ----
# Master switch for market calendar integration (holiday-aware stale checks,
# early-close detection). Set to false to use legacy weekday+fixed-hours logic.
MARKET_CALENDAR_ENABLED=true
# Optional comma-separated custom holidays (YYYY-MM-DD) per market
CUSTOM_HOLIDAYS_US=
CUSTOM_HOLIDAYS_HK=
# Optional JSON dict of early-close overrides per market: {"YYYY-MM-DD": "HH:MM"}
EARLY_CLOSES_US=
EARLY_CLOSES_HK=
# Actor market selection: "US" or "HK" enables calendar-aware hours
# (overrides manual timezone/open/close settings)
HEALTH_MONITOR_MARKET=
BAR_RESUB_MARKET=

# ---- Safety controls (circuit breakers) ----
# Max daily loss per strategy (positive number, 0 = disabled)
SAFETY_MAX_DAILY_LOSS=0
# Seconds without HealthMonitorActor heartbeat before logging CRITICAL
SAFETY_CONNECTIVITY_TIMEOUT_SECS=60
# Rejection streak threshold (must match RejectionMonitorActor config)
SAFETY_MAX_REJECTION_STREAK=3
