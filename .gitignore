# SAM Trader V3 — .gitignore
# Base ported from csam_trader v2, enhanced for v3.

# Ralph Wiggum Loop
.ralph_checkpoint.json
.ralph_loop.pid
logs/ralph_metrics.jsonl
logs/ralph_loop.log

# Beads / Dolt files
.dolt/
*.db
.beads-credential-key

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/

# Virtual environment
.venv/
venv/
env/

# Secrets (never commit)
.env
docker/.env
*.pem
config/bundles.yaml

# Parquet catalog (large binaries, local data)
data/catalog/*
!data/catalog/.gitkeep

# Docker volumes / runtime
backups/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Type checking
.mypy_cache/

# Testing
.pytest_cache/
.coverage
htmlcov/

# Large binaries / downloads
downloads/
logs/monitor*.log
logs/readiness/
logs/deploy_window.log
logs/safety.log

# Beads auto-exported metadata (passive exports — do not commit)
.beads/*.jsonl
